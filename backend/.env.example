# Copy to backend/.env for local development.
# In Vercel, add the same values in Project Settings > Environment Variables.

DATABASE_URL=postgresql://username:password@ep-xxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
PORT=3000

# Seed admin user for the users table
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Required for signing login tokens
AUTH_SECRET=replace-with-a-long-random-secret

# Allow admins to grant or remove admin access from other users
ALLOW_ADMIN_PRIVILEGE_CHANGES=false
